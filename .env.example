# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="UC CHRISTUS — Soporte"

# ─── Base de datos (PostgreSQL / Supabase) ───────────────────────────────────
# DATABASE_URL: pooler Transaction (6543) + ?pgbouncer=true
# DIRECT_URL:   pooler Session (5432) o conexión directa
DATABASE_URL=
DIRECT_URL=

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-con-openssl-rand-base64-32

# OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Soporte UC CHRISTUS <soporte@ucchristus.cl>"

# ─── Redis / Upstash (cache + BullMQ) ─────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Colas (BullMQ) ───────────────────────────────────────────────────────────
QUEUE_PREFIX=tickets-uc
EMAIL_QUEUE_CONCURRENCY=5

# ─── Storage ──────────────────────────────────────────────────────────────────
# dev: local | prod: s3
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage/uploads

# S3-compatible (prod)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=

# ─── Seguridad ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=32-byte-hex-for-email-passwords-at-rest
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# ─── API externa ──────────────────────────────────────────────────────────────
API_KEY_SALT=
